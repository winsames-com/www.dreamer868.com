---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceCategories = [
  { slug: 'financial-planning', label: '理財規劃', icon: '01', desc: '根據個人需求，制定專屬財務計劃，實現人生各階段目標。' },
  { slug: 'tax-planning', label: '稅務規劃', icon: '02', desc: '合法節稅策略，降低稅務負擔，保護您的資產。' },
  { slug: 'wealth-inheritance', label: '財富傳承', icon: '03', desc: '跨代財富規劃，確保家族資產安全傳承。' },
];

const moreServices = [
  { slug: 'overseas-banking', label: '海外銀行開戶', desc: '新加坡、香港銀行開戶代辦，拓展全球資產配置。' },
  { slug: 'family-governance', label: '家族治理', desc: '建立家族辦公室與治理機制，守護家族永續經營。' },
  { slug: 'trust-planning', label: '信託規劃', desc: '客製化信託方案，確保資產按照您的意願分配。' },
  { slug: 'insurance', label: '保險服務', desc: '保險不只是保障，也是傳承與節稅的重要工具。' },
];
---

<BaseLayout title="首頁">
  <!-- Hero Banner -->
  <section class="hero">
    <div class="hero-bg">
      <img src="https://www.doing-housework.com/store_image/dreamer868/A1173399369764.jpg" alt="尊茂財務規劃" />
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 data-animate-in="up">專業財務規劃</h1>
      <p data-animate-in="up">守護您的財富，規劃您的未來</p>
      <a href="/contact" class="hero-cta" data-animate-in="up">免費諮詢</a>
    </div>
  </section>

  <!-- About section -->
  <section class="section about-section">
    <div class="about-inner" data-animate-in="up">
      <img src="https://www.doing-housework.com/store_image/dreamer868/B2173399353292.jpg" alt="關於尊茂" />
      <div class="about-text">
        <h2 class="section-heading">關於尊茂財務規劃</h2>
        <p>尊茂財務規劃，不只是一間財務顧問公司——我們是您的「財務醫生」。</p>
        <p>我們不銷售商品，而是站在客戶的立場，先診斷、再處方、持續追蹤，提供「理性客觀、全面整合、長期有效」的財務規劃服務。</p>
        <a href="/about" class="text-link">了解更多 →</a>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="section services-section">
    <div class="services-grid">
      {serviceCategories.map((svc) => (
        <a href={`/services/${svc.slug}`} class="service-card" data-animate-in="up">
          <span class="service-number">{svc.icon}</span>
          <h3>{svc.label}</h3>
          <p>{svc.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- More services -->
  <section class="section more-services-section">
    <h2 class="section-heading centered" data-animate-in="up">更多服務項目</h2>
    <div class="more-services-grid">
      {moreServices.map((svc) => (
        <a href={`/services/${svc.slug}`} class="more-service-card" data-animate-in="up">
          <h4>{svc.label}</h4>
          <p>{svc.desc}</p>
          <span class="card-arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="cta-inner" data-animate-in="up">
      <h2>讓我們一起守護您的財富人生</h2>
      <p>不論您是個人、家庭或企業，尊茂都能提供最適合的財務規劃方案。</p>
      <a href="/contact" class="cta-button">立即諮詢</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 58, 147, 0.6) 0%,
      rgba(0, 0, 0, 0.3) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
  }

  .hero-content h1 {
    font-family: var(--font-serif);
    font-size: var(--f75);
    font-weight: 700;
    margin-bottom: 16px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .hero-content p {
    font-size: var(--f22);
    margin-bottom: 40px;
    opacity: 0.9;
  }

  .hero-cta {
    display: inline-block;
    padding: 14px 40px;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--f18);
    font-weight: 700;
    border-radius: 4px;
    transition: background 0.3s;
  }

  .hero-cta:hover {
    background: #b83b20;
  }

  /* Sections */
  .section {
    padding: 100px 20px;
  }

  /* About */
  .about-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  .about-inner > img {
    width: 45%;
    border-radius: 8px;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .about-text {
    flex: 1;
  }

  .about-text p {
    text-align: justify;
    margin-bottom: 1em;
  }

  .text-link {
    display: inline-block;
    color: var(--color-primary);
    font-weight: 700;
    margin-top: 10px;
    transition: color 0.3s;
  }

  .text-link:hover {
    color: var(--color-accent);
  }

  /* Services grid */
  .services-section {
    background: url('https://images.pexels.com/photos/7433853/pexels-photo-7433853.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=800&w=1200') center / cover fixed no-repeat;
    position: relative;
  }

  .services-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 58, 147, 0.85);
  }

  .services-grid {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .service-card {
    color: #fff;
    text-align: center;
    padding: 40px 30px;
    transition: transform 0.3s;
  }

  .service-card:hover {
    transform: translateY(-8px);
  }

  .service-number {
    display: block;
    font-family: var(--font-decorative);
    font-size: var(--f75);
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 20px;
  }

  .service-card h3 {
    font-size: var(--f22);
    margin-bottom: 16px;
    font-weight: 700;
  }

  .service-card p {
    font-size: 15px;
    opacity: 0.85;
    line-height: 1.8;
  }

  /* More services */
  .more-services-section {
    background: var(--color-bg-light);
  }

  .centered {
    text-align: center;
    margin-bottom: 50px;
  }

  .centered::after {
    margin: 10px auto 0;
  }

  .more-services-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .more-service-card {
    background: #fff;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.3s, box-shadow 0.3s;
    position: relative;
  }

  .more-service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }

  .more-service-card h4 {
    font-size: var(--f20);
    color: var(--color-primary);
    font-weight: 700;
    margin-bottom: 10px;
  }

  .more-service-card p {
    font-size: 14px;
    color: #666;
    line-height: 1.8;
  }

  .card-arrow {
    position: absolute;
    bottom: 20px;
    right: 20px;
    color: var(--color-accent);
    font-size: 20px;
    font-weight: 700;
  }

  /* CTA */
  .cta-section {
    background: var(--color-primary);
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    color: #fff;
  }

  .cta-inner h2 {
    font-family: var(--font-serif);
    font-size: var(--f32);
    margin-bottom: 16px;
  }

  .cta-inner p {
    font-size: var(--f18);
    opacity: 0.85;
    margin-bottom: 30px;
  }

  .cta-button {
    display: inline-block;
    padding: 14px 50px;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--f18);
    font-weight: 700;
    border-radius: 4px;
    transition: background 0.3s;
  }

  .cta-button:hover {
    background: #b83b20;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .about-inner {
      flex-direction: column-reverse;
    }

    .about-inner > img {
      width: 100%;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .more-services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .section {
      padding: 60px 16px;
    }

    .more-services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
