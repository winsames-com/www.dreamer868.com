---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import Icon from '../components/Icon.astro';
import { contactInfo } from '../data/navigation';
---

<BaseLayout title="聯絡我們">
  <PageBanner title="聯絡我們" />

  <section class="contact-page">
    <div class="contact-grid">
      <div class="contact-info">
        <h2>聯絡資訊</h2>
        <ul>
          <li>
            <Icon name="phone" />
            <div>
              <strong>電話</strong>
              <a href={`tel:${contactInfo.phone}`}>{contactInfo.phone}</a>
            </div>
          </li>
          <li>
            <Icon name="line" />
            <div>
              <strong>LINE ID</strong>
              <a href={contactInfo.lineUrl} target="_blank">{contactInfo.lineId}</a>
            </div>
          </li>
          <li>
            <Icon name="envelope" />
            <div>
              <strong>Email</strong>
              <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
            </div>
          </li>
          <li>
            <Icon name="location-dot" />
            <div>
              <strong>地址</strong>
              <span>{contactInfo.address}</span>
            </div>
          </li>
          <li>
            <Icon name="building" />
            <div>
              <strong>統一編號</strong>
              <span>{contactInfo.taxId}</span>
            </div>
          </li>
        </ul>
      </div>

      <div class="contact-form">
        <h2>預約諮詢</h2>
        <form id="contact-form">
          <div class="form-group">
            <label for="name">姓名 *</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="phone">電話</label>
              <input type="tel" id="phone" name="phone" />
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>
          <div class="form-group">
            <label for="message">諮詢內容 *</label>
            <textarea id="message" name="message" rows="6" required></textarea>
          </div>
          <button type="submit" class="submit-btn">送出</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 20px 100px;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .contact-info h2,
  .contact-form h2 {
    font-size: var(--text-lg);
    color: var(--color-primary);
    font-family: var(--font-serif);
    margin-bottom: 30px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--color-primary);
  }

  .contact-info ul {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact-info li {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .contact-info .icon {
    font-size: var(--text-base);
    color: var(--color-primary);
    margin-top: 4px;
    width: 24px;
    text-align: center;
  }

  .contact-info strong {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-ink-muted);
    margin-bottom: 4px;
  }

  .contact-info a:hover {
    color: var(--color-accent);
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    margin-bottom: 6px;
    color: var(--color-ink-soft);
  }

  input, textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid var(--color-line);
    border-radius: 4px;
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    transition: border-color 0.3s;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .submit-btn {
    display: inline-block;
    padding: 12px 40px;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: 700;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.3s;
  }

  .submit-btn:hover {
    background: var(--color-accent);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1.2fr;
      gap: 60px;
    }

    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script is:inline>
  document.getElementById('contact-form').addEventListener('submit', function(e) {
    e.preventDefault();
    const name = document.getElementById('name').value;
    const phone = document.getElementById('phone').value;
    const email = document.getElementById('email').value;
    const message = document.getElementById('message').value;
    const subject = encodeURIComponent('諮詢預約 - ' + name);
    const body = encodeURIComponent(
      '姓名：' + name + '\n' +
      '電話：' + phone + '\n' +
      'Email：' + email + '\n\n' +
      '諮詢內容：\n' + message
    );
    window.location.href = 'mailto:dreamer88888888888@gmail.com?subject=' + subject + '&body=' + body;
  });
</script>
