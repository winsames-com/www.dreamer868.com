---
import { mainNav, contactInfo } from '../data/navigation';
import Icon from './Icon.astro';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="https://www.doing-housework.com/store_image/dreamer868/L173380840389.png" alt="尊茂財務規劃" />
        <p class="footer-slogan">專業財務規劃，守護您的財富人生</p>
      </div>

      <div class="footer-links">
        <div class="footer-nav">
          <h4>服務項目</h4>
          <ul>
            <li><a href="/services/financial-planning">理財規劃</a></li>
            <li><a href="/services/tax-planning">稅務規劃</a></li>
            <li><a href="/services/wealth-inheritance">財富傳承</a></li>
            <li><a href="/services/overseas-banking">海外銀行開戶</a></li>
            <li><a href="/services/family-governance">家族治理</a></li>
            <li><a href="/services/trust-planning">信託規劃</a></li>
          </ul>
        </div>

        <div class="footer-contact">
          <h4>聯絡資訊</h4>
          <ul>
            <li>
              <Icon name="phone" />
              <a href={`tel:${contactInfo.phone}`}>{contactInfo.phone}</a>
            </li>
            <li>
              <Icon name="envelope" />
              <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
            </li>
            <li>
              <Icon name="location-dot" />
              <span>{contactInfo.address}</span>
            </li>
            <li>
              <Icon name="line" />
              <span>LINE ID: {contactInfo.lineId}</span>
            </li>
            <li>
              <Icon name="facebook-f" />
              <a href={contactInfo.facebookUrl} target="_blank" rel="noopener noreferrer">Facebook</a>
            </li>
            <li>
              <Icon name="building" />
              <span>統編: {contactInfo.taxId}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} 尊茂財務規劃 All Rights Reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: 60px 0 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 30px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--color-white-a20);
  }

  .footer-brand {
    flex: none;
    text-align: center;
  }

  .footer-brand img {
    height: 50px;
    width: auto;
    margin-bottom: 16px;
  }

  .footer-slogan {
    font-size: var(--text-xs);
    opacity: 0.8;
    line-height: 1.6;
  }

  .footer-links {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .footer-nav,
  .footer-contact {
    flex: 1;
  }

  .footer h4 {
    font-size: var(--text-sm);
    font-weight: 700;
    margin-bottom: 20px;
    position: relative;
    padding-bottom: 10px;
  }

  .footer h4::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--color-accent);
  }

  .footer-nav ul {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .footer-nav a {
    font-size: var(--text-xs);
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .footer-nav a:hover {
    opacity: 1;
  }

  .footer-contact ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: var(--text-xs);
    opacity: 0.8;
  }

  .footer-contact .icon {
    margin-top: 4px;
    width: 16px;
    text-align: center;
  }

  .footer-contact a:hover {
    text-decoration: underline;
  }

  .footer-bottom {
    padding: 20px 0;
    text-align: center;
    font-size: var(--text-xs);
    opacity: 0.6;
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      gap: 60px;
    }

    .footer-brand {
      flex: 0 0 250px;
      text-align: left;
    }

    .footer-links {
      flex-direction: row;
      gap: 60px;
    }
  }
</style>
