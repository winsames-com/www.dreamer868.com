---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from './PageBanner.astro';
import ArticleCard from './ArticleCard.astro';

interface Article {
  data: {
    title: string;
    slug: string;
    category: string;
    order: number;
    images: {
      hero: {
        url: string;
        alt: string;
      };
    };
  };
}

interface Props {
  title: string;
  description?: string;
  bannerImage?: string;
  articles: Article[];
}

const { title, description, bannerImage, articles } = Astro.props;
const sorted = [...articles].sort((a, b) => a.data.order - b.data.order);

// Service JSON-LD：把每個分類頁標成尊茂提供的服務（provider 指向全站 Organization 實體）
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  serviceType: title,
  ...(description && { description }),
  provider: { '@id': 'https://www.dreamer868.com/#organization' },
  areaServed: [
    { '@type': 'City', name: '台中市' },
    { '@type': 'Country', name: 'Taiwan' },
  ],
  inLanguage: 'zh-Hant-TW',
};

// ItemList：列出該分類下文章，幫 AI 理解此主題的內容深度與結構
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${title}相關文章`,
  itemListElement: sorted.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://www.dreamer868.com/articles/${a.data.slug}`,
    name: a.data.title,
  })),
};
---

<BaseLayout title={title} description={description} jsonLd={[serviceLd, itemListLd]}>
  <PageBanner title={title} backgroundImage={bannerImage} />

  <section class="category-content">
    {description && <p class="category-desc">{description}</p>}

    <div class="articles-grid">
      {sorted.map((article) => (
        <ArticleCard
          title={article.data.title}
          href={`/articles/${article.data.slug}`}
          image={article.data.images.hero.url}
          imageAlt={article.data.images.hero.alt}
          category={article.data.category}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .category-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 20px 100px;
  }

  .category-desc {
    font-size: var(--text-base);
    text-align: center;
    color: var(--color-ink-soft);
    margin-bottom: 50px;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  @media (min-width: 640px) {
    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .articles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
