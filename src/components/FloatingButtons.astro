---
import { contactInfo } from '../data/navigation';
import Icon from './Icon.astro';
---

<div class="floating-buttons">
  <a href={contactInfo.facebookUrl} target="_blank" rel="noopener noreferrer" class="float-btn facebook" aria-label="前往Facebook粉絲頁">
    <Icon name="facebook-f" />
  </a>
  <a href={contactInfo.lineUrl} target="_blank" rel="noopener noreferrer" class="float-btn line" aria-label="LINE聯繫">
    <Icon name="line" />
  </a>
  <a href={`tel:${contactInfo.phone}`} class="float-btn phone" aria-label="撥打電話">
    <Icon name="phone" />
  </a>
  <a href={`mailto:${contactInfo.email}`} class="float-btn mail" aria-label="寄送Email">
    <Icon name="envelope" />
  </a>
</div>

<style>
  .floating-buttons {
    position: fixed;
    right: 12px;
    bottom: 20px;
    z-index: 999;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .float-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    font-size: var(--text-sm);
    box-shadow: var(--shadow-float);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .float-btn:hover {
    transform: scale(1.1);
    box-shadow: var(--shadow-float-hover);
  }

  .float-btn.facebook {
    background: var(--color-social-fb);
  }

  .float-btn.line {
    background: var(--color-social-line);
  }

  .float-btn.phone {
    background: var(--color-primary);
  }

  .float-btn.mail {
    background: var(--color-accent);
  }

  @media (min-width: 768px) {
    .floating-buttons {
      right: 20px;
      bottom: 100px;
    }

    .float-btn {
      width: 50px;
      height: 50px;
      font-size: var(--text-base);
    }
  }
</style>
