---
interface Props {
  title: string;
  backgroundImage?: string;
}

const { title, backgroundImage = 'https://images.pexels.com/photos/7433853/pexels-photo-7433853.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=627&w=1200' } = Astro.props;
---

<div class="page-banner">
  <div class="banner-bg" style={`background-image: url(${backgroundImage})`}></div>
  <div class="banner-overlay"></div>
  <div class="banner-content">
    <h1>{title}</h1>
  </div>
</div>

<style>
  .page-banner {
    position: relative;
    height: 400px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .banner-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 58, 147, 0.8) 0%,
      rgba(0, 58, 147, 0.4) 100%
    );
  }

  .banner-content {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 40px 60px;
  }

  .banner-content h1 {
    font-family: var(--font-serif);
    font-size: var(--f40);
    color: #fff;
    font-weight: 700;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  @media (max-width: 1024px) {
    .page-banner {
      height: 300px;
    }
  }

  @media (max-width: 768px) {
    .page-banner {
      height: 220px;
    }

    .banner-content {
      padding: 0 20px 30px;
    }

    .banner-content h1 {
      font-size: var(--f28);
    }
  }
</style>
