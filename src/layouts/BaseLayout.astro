---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import { contactInfo } from '../data/navigation';
import '../styles/global.css';

interface BreadcrumbItem {
  name: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  author?: string;
  breadcrumbs?: BreadcrumbItem[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const defaultOgImage = 'https://www.doing-housework.com/store_image/dreamer868/A1173399369764.jpg';

const {
  title,
  description = '台中稅務規劃公司,台中財產繼承規劃,我們利用專業的理財規劃知識，根據每位客戶的個別需求，提供全面的理財諮詢和建議，協助他們實現財務目標。',
  keywords = '稅務規劃,理財規劃,財富傳承,財務顧問,台中理財顧問,海外銀行開戶,家族治理,信託規劃',
  ogImage = defaultOgImage,
  ogType = 'website',
  author,
  breadcrumbs = [],
  jsonLd,
} = Astro.props;

const siteTitle = `${title} | 尊茂財務規劃`;
const canonicalUrl = Astro.url.href;

// 頁面專用 JSON-LD 統一成陣列，方便逐一輸出 <script>
const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// 全站實體錨點：Organization + WebSite（每頁輸出，幫 AI/搜尋引擎辨識「尊茂財務規劃」這個實體）
const orgLd = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'FinancialService'],
  '@id': 'https://www.dreamer868.com/#organization',
  name: '尊茂財務規劃',
  url: 'https://www.dreamer868.com',
  logo: defaultOgImage,
  image: defaultOgImage,
  telephone: contactInfo.phone,
  email: contactInfo.email,
  taxID: contactInfo.taxId,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '文心路一段186號9樓之1',
    addressLocality: '南屯區',
    addressRegion: '台中市',
    postalCode: '408',
    addressCountry: 'TW',
  },
  areaServed: [
    { '@type': 'City', name: '台中市' },
    { '@type': 'Country', name: 'Taiwan' },
  ],
  knowsAbout: ['理財規劃', '稅務規劃', '財富傳承', '海外銀行開戶', '家族治理', '信託規劃', '保險服務', '移民規劃', '二代培訓', '租稅服務', '地政士服務', '國際貿易', '海外基金債券'],
  sameAs: [contactInfo.lineUrl, contactInfo.facebookUrl],
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://www.dreamer868.com/#website',
  name: '尊茂財務規劃',
  url: 'https://www.dreamer868.com',
  inLanguage: 'zh-Hant-TW',
  publisher: { '@id': 'https://www.dreamer868.com/#organization' },
};

const breadcrumbItems: BreadcrumbItem[] = [
  { name: '首頁', href: '/' },
  ...breadcrumbs,
];

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: `https://www.dreamer868.com${item.href}`,
  })),
};
---

<!DOCTYPE html>
<html lang="zh-Hant-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  {author && <meta name="author" content={author} />}

  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:locale" content="zh_TW" />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="尊茂財務規劃" />
  <meta property="og:title" content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <title>{siteTitle}</title>
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="alternate" type="application/rss+xml" title="尊茂財務規劃 — 文章 RSS" href="/rss.xml" />
  <link rel="alternate" type="text/plain" title="llms.txt" href="/llms.txt" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Noto+Serif+TC:wght@400;700&family=Tiro+Devanagari+Hindi&display=swap"
    rel="stylesheet"
  />

  <!-- Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />

  <!-- 全站實體：Organization + WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />

  <!-- BreadcrumbList JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

  <!-- Page-specific JSON-LD -->
  {jsonLdList.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)}

  <!-- Google Analytics (ID 單一來源：src/data/navigation.ts) -->
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${contactInfo.googleAnalyticsId}`}></script>
  <script is:inline define:vars={{ gaId: contactInfo.googleAnalyticsId }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', gaId);
  </script>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <FloatingButtons />

  <!-- Scroll animation observer -->
  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('[data-animate-in]').forEach(el => observer.observe(el));
  </script>
</body>
</html>
