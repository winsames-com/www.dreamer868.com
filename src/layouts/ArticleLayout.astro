---
import BaseLayout from './BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';

interface FaqItem { q: string; a: string; }

interface Props {
  title: string;
  description?: string;
  heroImage?: string;
  heroAlt?: string;
  credit?: string;
  category?: string;
  date?: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
  authorTitle?: string;
  authorUrl?: string;
  slug?: string;
  caseStory?: boolean;
  caseSource?: string;
  faq?: FaqItem[];
}

const {
  title, description, heroImage, heroAlt, credit, category, date, updatedDate,
  tags, author, authorTitle, authorUrl, slug, caseStory, caseSource, faq,
} = Astro.props;

const url = `https://www.dreamer868.com/articles/${slug || ''}`;
const published = date ? date.toISOString() : undefined;
const modified = (updatedDate || date)?.toISOString();

// 具名作者（有頭銜才升級為 Person，否則沿用機構作者）——YMYL 不捏造資歷，只用實際填入的資料
const isNamedAuthor = !!author && author !== 'Writer' && !!authorTitle;
const authorLd = isNamedAuthor
  ? {
      '@type': 'Person',
      name: author,
      jobTitle: authorTitle,
      ...(authorUrl && { url: `https://www.dreamer868.com${authorUrl}` }),
      worksFor: { '@type': 'Organization', name: '尊茂財務規劃', url: 'https://www.dreamer868.com' },
    }
  : { '@type': 'Organization', name: '尊茂財務規劃', url: 'https://www.dreamer868.com' };

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(description && { description }),
  ...(heroImage && { image: heroImage }),
  ...(published && { datePublished: published, dateModified: modified }),
  ...(category && { articleSection: category }),
  ...(tags && tags.length && { keywords: tags.join(', ') }),
  inLanguage: 'zh-Hant-TW',
  author: authorLd,
  publisher: {
    '@type': 'Organization',
    name: '尊茂財務規劃',
    url: 'https://www.dreamer868.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.doing-housework.com/store_image/dreamer868/A1173399369764.jpg',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

// FAQPage：有問答對才輸出，讓 AI 答題引擎直接抽取
const faqLd = faq && faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

const jsonLd = faqLd ? [articleLd, faqLd] : articleLd;

const breadcrumbs = [
  ...(category ? [{ name: category, href: '/services' }] : []),
  { name: title, href: `/articles/${slug || ''}` },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={tags && tags.length ? tags.join(',') : undefined}
  author={isNamedAuthor ? author : undefined}
  ogImage={heroImage}
  ogType="article"
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>
  <PageBanner title={title} backgroundImage={heroImage} />

  <article class="article-page">
    <div class="article-meta">
      {category && <span class="category-tag">{category}</span>}
      {isNamedAuthor && (
        <span class="byline" itemscope itemtype="https://schema.org/Person">
          {authorUrl
            ? <a href={authorUrl} itemprop="url"><span itemprop="name">{author}</span></a>
            : <span itemprop="name">{author}</span>}
          <span class="author-title" itemprop="jobTitle">{authorTitle}</span>
        </span>
      )}
      {date && <time datetime={(updatedDate || date).toISOString()}>{(updatedDate || date).toLocaleDateString('zh-TW')}{updatedDate && ' 更新'}</time>}
    </div>

    {caseStory && (
      <aside class="case-disclaimer" role="note" aria-label="案例免責聲明">
        <p>本文改編自真實法院判決，為保護當事人隱私，人物均為化名、情節經改編，僅供財務規劃情境參考，不構成法律或稅務意見。</p>
        {caseSource && <p class="case-source">參考判決：{caseSource}</p>}
      </aside>
    )}

    <div class="prose">
      <slot />
    </div>

    {credit && <p class="photo-credit">{credit}</p>}
  </article>
</BaseLayout>

<style>
  .article-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px 100px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--color-bg-light);
  }

  .category-tag {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 4px 14px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
  }

  time {
    color: #999;
    font-size: 14px;
  }

  .byline {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-size: 14px;
    color: #555;
  }

  .byline a { color: var(--color-primary); text-decoration: none; font-weight: 600; }
  .byline a:hover { text-decoration: underline; }
  .byline .author-title { color: #999; font-size: 13px; }

  .photo-credit {
    text-align: center;
    font-size: 12px;
    color: #999;
    margin-top: 40px;
  }

  .case-disclaimer {
    background: var(--color-bg-light);
    border-left: 4px solid var(--color-primary);
    padding: 16px 20px;
    margin-bottom: 32px;
    border-radius: 4px;
  }

  .case-disclaimer p {
    font-size: 14px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .case-disclaimer .case-source {
    margin-top: 8px;
    font-weight: 600;
    color: var(--color-primary);
  }
</style>
