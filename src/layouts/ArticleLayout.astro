---
import BaseLayout from './BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';

interface Props {
  title: string;
  description?: string;
  heroImage?: string;
  heroAlt?: string;
  credit?: string;
  category?: string;
  date?: Date;
  slug?: string;
  caseStory?: boolean;
  caseSource?: string;
}

const { title, description, heroImage, heroAlt, credit, category, date, slug, caseStory, caseSource } = Astro.props;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(description && { description }),
  ...(heroImage && { image: heroImage }),
  ...(date && {
    datePublished: date.toISOString(),
    dateModified: date.toISOString(),
  }),
  author: {
    '@type': 'Organization',
    name: '尊茂財務規劃',
    url: 'https://www.dreamer868.com',
  },
  publisher: {
    '@type': 'Organization',
    name: '尊茂財務規劃',
    url: 'https://www.dreamer868.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.doing-housework.com/store_image/dreamer868/A1173399369764.jpg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://www.dreamer868.com/articles/${slug || ''}`,
  },
};

const breadcrumbs = [
  ...(category ? [{ name: category, href: '/services' }] : []),
  { name: title, href: `/articles/${slug || ''}` },
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage={heroImage}
  jsonLd={articleLd}
  breadcrumbs={breadcrumbs}
>
  <PageBanner title={title} backgroundImage={heroImage} />

  <article class="article-page">
    <div class="article-meta">
      {category && <span class="category-tag">{category}</span>}
      {date && <time datetime={date.toISOString()}>{date.toLocaleDateString('zh-TW')}</time>}
    </div>

    {caseStory && (
      <aside class="case-disclaimer" role="note" aria-label="案例免責聲明">
        <p>本文改編自真實法院判決，為保護當事人隱私，人物均為化名、情節經改編，僅供財務規劃情境參考，不構成法律或稅務意見。</p>
        {caseSource && <p class="case-source">參考判決：{caseSource}</p>}
      </aside>
    )}

    <div class="prose">
      <slot />
    </div>

    {credit && <p class="photo-credit">{credit}</p>}
  </article>
</BaseLayout>

<style>
  .article-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px 100px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--color-bg-light);
  }

  .category-tag {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 4px 14px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
  }

  time {
    color: #999;
    font-size: 14px;
  }

  .photo-credit {
    text-align: center;
    font-size: 12px;
    color: #999;
    margin-top: 40px;
  }

  .case-disclaimer {
    background: var(--color-bg-light);
    border-left: 4px solid var(--color-primary);
    padding: 16px 20px;
    margin-bottom: 32px;
    border-radius: 4px;
  }

  .case-disclaimer p {
    font-size: 14px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .case-disclaimer .case-source {
    margin-top: 8px;
    font-weight: 600;
    color: var(--color-primary);
  }
</style>
