---
import BaseLayout from './BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import { principalAuthor } from '../data/navigation';

interface FaqItem { q: string; a: string; }
interface RelatedItem { title: string; slug: string; }
interface Heading { depth: number; slug: string; text: string; }

interface Props {
  title: string;
  description?: string;
  heroImage?: string;
  heroAlt?: string;
  credit?: string;
  category?: string;
  date?: Date;
  updatedDate?: Date;
  tags?: string[];
  author?: string;
  authorTitle?: string;
  authorUrl?: string;
  slug?: string;
  caseStory?: boolean;
  caseSource?: string;
  faq?: FaqItem[];
  related?: RelatedItem[];
  toc?: Heading[];
}

const {
  title, description, heroImage, heroAlt, credit, category, date, updatedDate,
  tags, author, authorTitle, authorUrl, slug, caseStory, caseSource, faq, related, toc,
} = Astro.props;

const url = `https://www.dreamer868.com/articles/${slug || ''}/`;
const published = date ? date.toISOString() : undefined;
const modified = (updatedDate || date)?.toISOString();

// 具名作者：frontmatter 有指定具名作者(含頭銜)則用之，否則一律掛主顧問（吳芳圳）。
// YMYL 不捏造資歷，作者資料集中於 navigation.ts 的 principalAuthor。
const hasFrontmatterAuthor = !!author && author !== 'Writer' && !!authorTitle;
const eff = hasFrontmatterAuthor
  ? { name: author!, title: authorTitle!, url: authorUrl, personId: undefined as string | undefined }
  : principalAuthor;
const authorLd = {
  '@type': 'Person',
  ...(eff.personId && { '@id': eff.personId }),
  name: eff.name,
  jobTitle: eff.title,
  ...(eff.url && { url: `https://www.dreamer868.com${eff.url}` }),
  worksFor: { '@type': 'Organization', name: '尊茂財務規劃', url: 'https://www.dreamer868.com' },
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(description && { description }),
  ...(heroImage && { image: heroImage }),
  ...(published && { datePublished: published, dateModified: modified }),
  ...(category && { articleSection: category }),
  ...(tags && tags.length && { keywords: tags.join(', ') }),
  inLanguage: 'zh-Hant-TW',
  author: authorLd,
  publisher: {
    '@type': 'Organization',
    name: '尊茂財務規劃',
    url: 'https://www.dreamer868.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.doing-housework.com/store_image/dreamer868/A1173399369764.jpg',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
};

// FAQPage：有問答對才輸出，讓 AI 答題引擎直接抽取
const faqLd = faq && faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

const jsonLd = faqLd ? [articleLd, faqLd] : articleLd;

const breadcrumbs = [
  ...(category ? [{ name: category, href: '/services/' }] : []),
  { name: title, href: `/articles/${slug || ''}/` },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={tags && tags.length ? tags.join(',') : undefined}
  author={eff.name}
  ogImage={heroImage}
  ogType="article"
  jsonLd={jsonLd}
  breadcrumbs={breadcrumbs}
>
  <PageBanner title={title} backgroundImage={heroImage} />

  <article class="article-page">
    <div class="article-meta">
      {category && <span class="category-tag">{category}</span>}
      <span class="byline" itemscope itemtype="https://schema.org/Person">
        {eff.url
          ? <a href={eff.url} itemprop="url"><span itemprop="name">{eff.name}</span></a>
          : <span itemprop="name">{eff.name}</span>}
        <span class="author-title" itemprop="jobTitle">{eff.title}</span>
      </span>
      {date && <time datetime={(updatedDate || date).toISOString()}>{(updatedDate || date).toLocaleDateString('zh-TW')}{updatedDate && ' 更新'}</time>}
    </div>

    {toc && toc.length >= 3 && (
      <nav class="toc" aria-label="本文目錄">
        <p class="toc-title">本文目錄</p>
        <ul>
          {toc.map((h) => (
            <li class={`toc-d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ul>
      </nav>
    )}

    {caseStory && (
      <aside class="case-disclaimer" role="note" aria-label="案例免責聲明">
        <p>本文改編自真實法院判決，為保護當事人隱私，人物均為化名、情節經改編，僅供財務規劃情境參考，不構成法律或稅務意見。</p>
        {caseSource && <p class="case-source">參考判決：{caseSource}</p>}
      </aside>
    )}

    <div class="prose">
      <slot />
    </div>

    {faq && faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">常見問答</h2>
        {faq.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </section>
    )}

    {related && related.length > 0 && (
      <nav class="related" aria-label="相關閱讀">
        <h2>相關閱讀</h2>
        <ul>
          {related.map((r) => (
            <li><a href={`/articles/${r.slug}/`}>{r.title}</a></li>
          ))}
        </ul>
      </nav>
    )}

    {credit && <p class="photo-credit">{credit}</p>}
  </article>
</BaseLayout>

<style>
  .article-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 60px 20px 100px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 2px solid var(--color-bg-light);
  }

  .category-tag {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 4px 14px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 500;
  }

  time {
    color: #999;
    font-size: 14px;
  }

  .byline {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-size: 14px;
    color: #555;
  }

  .byline a { color: var(--color-primary); text-decoration: none; font-weight: 600; }
  .byline a:hover { text-decoration: underline; }
  .byline .author-title { color: #999; font-size: 13px; }

  .photo-credit {
    text-align: center;
    font-size: 12px;
    color: #999;
    margin-top: 40px;
  }

  .faq {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 2px solid var(--color-bg-light);
  }

  .faq h2 {
    font-size: var(--f28, 1.6rem);
    margin-bottom: 24px;
    color: var(--color-primary);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-bg-light);
    padding: 16px 0;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 17px;
    line-height: 1.6;
    color: #333;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: '＋ '; color: var(--color-primary); font-weight: 700; }
  .faq-item[open] summary::before { content: '－ '; }

  .faq-item p {
    margin: 12px 0 0;
    padding-left: 1.4em;
    color: #555;
    line-height: 1.8;
  }

  .related {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 2px solid var(--color-bg-light);
  }

  .related h2 {
    font-size: var(--f28, 1.6rem);
    margin-bottom: 20px;
    color: var(--color-primary);
  }

  .related ul { list-style: none; padding: 0; margin: 0; }

  .related li {
    padding: 12px 0;
    border-bottom: 1px solid var(--color-bg-light);
  }

  .related a {
    color: #333;
    text-decoration: none;
    font-weight: 500;
  }

  .related a:hover { color: var(--color-primary); text-decoration: underline; }

  .toc {
    background: var(--color-bg-light);
    border-radius: 8px;
    padding: 20px 24px;
    margin-bottom: 36px;
  }

  .toc-title {
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 12px;
    font-size: 16px;
  }

  .toc ul { list-style: none; padding: 0; margin: 0; }
  .toc li { padding: 4px 0; line-height: 1.6; }
  .toc-d3 { padding-left: 1.4em; font-size: 14px; }
  .toc a { color: #555; text-decoration: none; }
  .toc a:hover { color: var(--color-primary); text-decoration: underline; }

  html { scroll-behavior: smooth; }

  .case-disclaimer {
    background: var(--color-bg-light);
    border-left: 4px solid var(--color-primary);
    padding: 16px 20px;
    margin-bottom: 32px;
    border-radius: 4px;
  }

  .case-disclaimer p {
    font-size: 14px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .case-disclaimer .case-source {
    margin-top: 8px;
    font-weight: 600;
    color: var(--color-primary);
  }
</style>
