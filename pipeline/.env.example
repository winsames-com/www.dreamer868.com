# 複製為 pipeline/.env（已 gitignore）並填入司法院資料開放平臺帳密。
JUD_USER=your_judicial_account
JUD_PASS=your_judicial_password

# 改編引擎 = claude -p（訂閱帳戶）。
# - 本機已 `claude` 登入：不需下面這行。
# - 伺服器（headless，無法互動登入）：在已登入的機器跑 `claude setup-token`，
#   把產生的長效 token 填到這裡；claude -p 會自動讀取。
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat...

# 取消註解可乾跑（抓取+分類+改編+閘門全跑，但不寫正式檔、不更新帳本、不 commit）
# DRY_RUN=1
